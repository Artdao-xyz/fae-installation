# Exhibition kiosk UI (session receipt, screensaver, stripped chrome)
NEXT_PUBLIC_FAE_INSTALLATION_MODE=1

# CMS catalog: `local` (data/catalog.json) or `strapi` (live API)
# Omit to auto-pick: local when data/catalog.json exists, otherwise Strapi.
FAE_DATA_SOURCE=local

# Live Strapi (required when FAE_DATA_SOURCE=strapi, or when no local catalog)
STRAPI_URL=https://your-strapi.example
STRAPI_API_TOKEN=

# Receipt QR base URL (Vercel / public deploy — use your production origin)
# NEXT_PUBLIC_RECEIPT_VIEW_BASE_URL=https://your-app.vercel.app

# Thermal printer (kiosk only — not used on Vercel)
# RECEIPT_PRINTER_INTERFACE=printer:Receipt_Printer

# Admin PIN for /admin (default: fae)
# INSTALLATION_ADMIN_PIN=fae

# Dev-only: bundled fixture instead of Strapi/local
# FAE_USE_STRAPI_FIXTURE=1
